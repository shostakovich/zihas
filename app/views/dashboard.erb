<h1>Zipfelmaus — Stromübersicht</h1>

<div id="live-zone">
  <%= erb :live, layout: false %>
</div>

<div id="summary-zone">
  <%= erb :summary, layout: false %>
</div>

<div class="section-label">Heute — Leistung über Zeit</div>
<div class="chart-card">
  <img id="today-chart" src="/charts/today.png" alt="Leistung heute">
</div>

<div class="section-label">Letzte 14 Tage — Tages-Ertrag</div>
<div class="chart-card">
  <img id="history-chart" src="/charts/history.png" alt="14-Tage-Verlauf">
</div>

<script>
  function poll(id, url, ms) {
    const el = document.getElementById(id);
    const run = () => fetch(url).then(r => r.text()).then(html => { el.innerHTML = html; }).catch(console.error);
    setInterval(run, ms);
  }

  function refreshChart(id, url, ms) {
    setInterval(() => { document.getElementById(id).src = url + "?" + Date.now(); }, ms);
  }

  poll("live-zone",    "/fragments/live",    5_000);
  poll("summary-zone", "/fragments/summary", 10_000);
  refreshChart("today-chart",   "/charts/today.png",   60_000);
  refreshChart("history-chart", "/charts/history.png", 3_600_000);
</script>
