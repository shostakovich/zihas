<%# app/views/lights/_form.html.erb %>
<%= form_with model: light, class: "ld-form" do |f| %>
  <% if light.errors.any? %>
    <ul class="form-errors">
      <% light.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
    </ul>
  <% end %>

  <div class="ld-field">
    <%= f.label :name, "Name", class: "ld-field-label" %>
    <%= f.text_field :name, class: "ld-input" %>
  </div>

  <div class="ld-field">
    <%= f.label :shelly_plug_id, "Shelly-Plug", class: "ld-field-label" %>
    <%= f.select :shelly_plug_id,
          options_for_select(plugs.map { |p| [ p.name, p.id ] }, light.shelly_plug_id),
          { include_blank: "— keine —" },
          { class: "ld-input ld-select" } %>
  </div>

  <div class="ld-form-actions">
    <%= link_to "Abbrechen", light_path(light.key), class: "ld-btn ld-btn-ghost" %>
    <%= f.submit "Speichern", class: "ld-btn ld-btn-primary" %>
  </div>
<% end %>
