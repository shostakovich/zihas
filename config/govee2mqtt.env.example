# Copy to config/govee2mqtt.env (gitignored) and fill in.
# Govee account (needed for room names + cloud scenes/capabilities)
GOVEE_EMAIL=you@example.com
GOVEE_PASSWORD=changeme
# Govee API key (https://developer.govee.com/reference/apply-you-govee-api-key)
GOVEE_API_KEY=00000000-0000-0000-0000-000000000000

# MQTT broker — MUST be the same broker ZiWoAS uses: set this to the exact
# `mqtt.host` from config/ziwoas.yml. Do NOT use 127.0.0.1 — with the prod
# container's network_mode: host that resolves to the host's own loopback (a
# different broker), and commands/state/discovery would silently never cross
# between ZiWoAS and govee2mqtt.
GOVEE_MQTT_HOST=192.168.1.103
GOVEE_MQTT_PORT=1883
#GOVEE_MQTT_USER=
#GOVEE_MQTT_PASSWORD=

GOVEE_TEMPERATURE_SCALE=C
TZ=Europe/Berlin
